{
  "$schema": "https://design-system.schema.org/v1",
  "name": "Muneeb Design System",
  "version": "1.0.0",
  "description": "Design tokens for the Muneeb portfolio",

  "colors": {
    "primary": "#2A29FF",
    "blue": "#29FFFF",
    "black": "#171717",
    "mainBlack": "#232323",
    "white": "#FFFFFF",
    "gray": "#F6F6F6",
    "border": "#E9E9E9",
    "borderLight": "#EAEAEA",
    "textMuted": "rgba(23,23,23,0.6)",
    "textSubtle": "rgba(23,23,23,0.5)",
    "textFaint": "rgba(23,23,23,0.4)",
    "whiteMuted": "rgba(255,255,255,0.8)",
    "whiteSubtle": "rgba(255,255,255,0.6)",
    "green": "#9EF34A"
  },

  "typography": {
    "fontFamily": {
      "base": "Manrope, sans-serif",
      "fallback": "Arial, Helvetica, sans-serif"
    },
    "fontWeights": {
      "semiBold": 600,
      "bold": 700
    },
    "fontSizes": {
      "xs": "11px",
      "sm": "13px",
      "base": "14px",
      "md": "16px",
      "lg": "17px",
      "xl": "18px",
      "2xl": "20px",
      "3xl": "22px",
      "4xl": "28px",
      "5xl": "38px",
      "6xl": "45px",
      "7xl": "50px",
      "8xl": "52px",
      "9xl": "65px",
      "hero": "72px"
    },
    "letterSpacing": {
      "tight": "-0.65px",
      "normal": "-0.56px",
      "wide": "-0.88px",
      "hero": "-3.6px",
      "heading": "-2.5px",
      "display": "-3.9px"
    },
    "lineHeight": {
      "none": 1,
      "tight": 1.2,
      "snug": 1.3,
      "normal": 1.4,
      "relaxed": 1.5
    }
  },

  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "10px",
    "4": "12px",
    "5": "14px",
    "6": "16px",
    "7": "18px",
    "8": "20px",
    "9": "22px",
    "10": "24px",
    "12": "28px",
    "14": "32px",
    "16": "36px",
    "18": "40px",
    "20": "44px",
    "24": "52px",
    "28": "58px",
    "32": "64px",
    "40": "80px",
    "section": "60px"
  },

  "borderRadius": {
    "sm": "9px",
    "md": "18px",
    "lg": "36px",
    "xl": "40px",
    "2xl": "41px",
    "3xl": "42px",
    "4xl": "46px",
    "full": "100px",
    "pill": "50px"
  },

  "shadows": {
    "card": "0px 7px 26.5px 0px rgba(0,0,0,0.03)",
    "cardHover": "0px 9px 13px 0px rgba(0,0,0,0.14)",
    "icon": "0px 6px 12px 0px rgba(0,0,0,0.15)",
    "pill": "0px 1px 6px 0px rgba(0,0,0,0.09)"
  },

  "components": {
    "button": {
      "primary": {
        "background": "#2A29FF",
        "color": "#FFFFFF",
        "height": "58px",
        "borderRadius": "100px",
        "paddingLeft": "28px",
        "paddingRight": "3px",
        "fontSize": "17px",
        "fontWeight": 600,
        "letterSpacing": "-0.68px"
      },
      "secondary": {
        "background": "#F6F6F6",
        "color": "#171717",
        "height": "58px",
        "borderRadius": "100px",
        "padding": "20px 28px",
        "fontSize": "17px",
        "fontWeight": 600,
        "letterSpacing": "-0.68px"
      },
      "ghost": {
        "background": "transparent",
        "color": "#171717",
        "fontSize": "14px",
        "fontWeight": 600,
        "letterSpacing": "-0.7px"
      }
    },
    "card": {
      "borderRadius": "36px",
      "background": "#FFFFFF",
      "border": "1px solid #E9E9E9",
      "padding": "24px"
    },
    "section": {
      "maxWidth": "550px",
      "paddingX": "0px",
      "gap": "60px"
    },
    "badge": {
      "background": "#F6F6F6",
      "borderRadius": "50px",
      "padding": "6px 8px 6px 6px",
      "fontSize": "11px",
      "fontWeight": 600
    }
  },

  "layout": {
    "pageWidth": "550px",
    "containerPadding": "0px",
    "sectionGap": "60px",
    "mobileBreakpoint": "390px"
  },

  "assets": {
    "localServerBase": "http://localhost:3845/assets/"
  }
}
